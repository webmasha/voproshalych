# Bot Core
BOT_CORE_APP_NAME=bot-core
BOT_CORE_APP_VERSION=0.1.0
BOT_CORE_URL=http://bot-core:8000
BOT_CORE_TIMEOUT_SECONDS=300
TELEGRAM_BOT_TOKEN=
VK_BOT_TOKEN=
MAX_BOT_TOKEN=
MAX_BOT_INTERNAL_URL=http://max-bot:8081
MAX_BOT_INTERNAL_PORT=8081

# Database
POSTGRES_DB=voproshalych
POSTGRES_USER=voproshalych
POSTGRES_PASSWORD=voproshalych
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# LLM Providers
MISTRAL_API_KEY=
MISTRAL_MODEL=open-mistral-nemo
OPENROUTER_API_KEY=
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=

# Embeddings
EMBEDDING_MODEL=deepvk/USER-bge-m3

# HuggingFace (для скачивания моделей эмбеддингов)
HF_TOKEN=

# Confluence
CONFLUENCE_TOKEN=
CONFLUENCE_HOST=https://confluence.utmn.ru

# QA Service
QA_SERVICE_URL=http://qa-service:8004
QA_SERVICE_TIMEOUT_SECONDS=300
DIALOG_CONTEXT_LIMIT_MESSAGES=7
HOLIDAY_NEWSLETTER_ENABLED=true
HOLIDAY_NEWSLETTER_RUN_HOUR=9
HOLIDAY_NEWSLETTER_RUN_MINUTE=0

# LightRAG (Hybrid Search + Knowledge Graph)
USE_LIGHT_RAG=false
LIGHT_RAG_WORKING_DIR=/app/lightrag_data
LIGHT_RAG_STORAGE_TYPE=PostgreSQL
LIGHT_RAG_POSTGRES_URI=postgresql://voproshalych:voproshalych@postgres:5432/voproshalych
LIGHT_RAG_MODEL_NAME=deepvk-user-bge-m3
LIGHT_RAG_LLM_FOR_INDEXING=openrouter/free
